# Application
APP_NAME=Photo Printing Management System
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
DEBUG=true

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=photo_printing
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/photo_printing

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/app/uploads
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=photo-printing
S3_REGION=us-east-1

# Frontend
NEXT_PUBLIC_API_URL=/api/v1
FRONTEND_URL=http://localhost

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Email (for password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@system.com

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
